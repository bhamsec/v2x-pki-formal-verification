

(*	ETSI-TS 102940 v2.1.1 2021-07			*)
(*	Architecture without Butterfly Key Expansion	*)
(*	Authorization request with POP and Privacy	*)
(*	No attacker vehicle				*)
(*	Phases to model validity and expiration time	*)
(*	NO ELSE BRANCHES					*)

set ignoreTypes = false.
(* set selFun = Nounifset. *)

(*	TYPES						*)
type pkey.
type skey.
type symkey.
type hmackey.
type certype.
type enrcertype.
type result.
type timestamp.
type hashcertype.
type hashenrcertype.
type hashkeytype.


(*	FREE TERMS					*)
free ch:channel.
free rootca_sk:skey [private].


(*	CONSTANTS					*)
const EA:bitstring.
const AA:bitstring.
const SELF:bitstring.
const RESPONSE_CODE_0_ENR:bitstring.
const RESPONSE_CODE_0_AUTH:bitstring.
const RESPONSE_CODE_0_AUTHVAL:bitstring.
const RESPONSE_CODE_1_ENR:bitstring.
const RESPONSE_CODE_1_AUTH:bitstring.
const RESPONSE_CODE_1_AUTHVAL:bitstring.
const NULL_SYMK:bitstring.
const NULL_PK:pkey.
const NULL_CERT:certype.
const NULL_STRING:bitstring.
const NULL_TIMESTAMP:timestamp.
const ERROR_negative_response_from_ea:bitstring.
const ERROR_wrong_signature_or_hash:bitstring.
const ERROR_enrolled_not_found:bitstring.
const ERROR_wrong_singatures_enrollment:bitstring.
const ERROR_registered_not_found:bitstring.
const ENR_cert:bitstring.


(*	EVENTS						*)
event ValidEnrollmentCertReceived(skey, enrcertype).
event ValidEnrollmentCertSent(enrcertype).
event ValidAuthorizationTicketReceivedPH0(skey, certype).
event ValidAuthorizationTicketReceivedPH1(skey, certype).
event ValidAuthorizationTicketReceivedPH2(skey, certype).
event ValidAuthorizationTicketReceivedPH3(skey, certype).
event ErrorMessage(bitstring).
event VehicleEnrolmentRequestSent(bitstring).
event VehicleEnrolmentResponseReceived(bitstring).
event EAEnrolmentRequestReceived(bitstring).
event EAEnrolmentResponseSent(bitstring).
event VehicleAuthorizationRequestSentPH0(bitstring).
event VehicleAuthorizationRequestSentPH1(bitstring).
event VehicleAuthorizationRequestSentPH2(bitstring).
event VehicleAuthorizationRequestSentPH3(bitstring).
event AAAuthorizationRequestReceivedPH0(bitstring).
event AAAuthorizationRequestReceivedPH1(bitstring).
event AAAuthorizationRequestReceivedPH2(bitstring).
event AAAuthorizationRequestReceivedPH3(bitstring).
event AAAuthorizationValidationRequestSentPH0(bitstring).
event AAAuthorizationValidationRequestSentPH1(bitstring).
event AAAuthorizationValidationRequestSentPH2(bitstring).
event AAAuthorizationValidationRequestSentPH3(bitstring).
event EAAuthorizationValidationRequestReceivedPH0(bitstring).
event EAAuthorizationValidationRequestReceivedPH1(bitstring).
event EAAuthorizationValidationRequestReceivedPH2(bitstring).
event EAAuthorizationValidationRequestReceivedPH3(bitstring).
event EAAuthorizationValidationResponseSentPH0(bitstring).
event EAAuthorizationValidationResponseSentPH1(bitstring).
event EAAuthorizationValidationResponseSentPH2(bitstring).
event EAAuthorizationValidationResponseSentPH3(bitstring).
event AAAuthorizationValidationResponseReceivedPH0(bitstring).
event AAAuthorizationValidationResponseReceivedPH1(bitstring).
event AAAuthorizationValidationResponseReceivedPH2(bitstring).
event AAAuthorizationValidationResponseReceivedPH3(bitstring).
event AAAuthorizationResponseSentPH0(bitstring).
event AAAuthorizationResponseSentPH1(bitstring).
event AAAuthorizationResponseSentPH2(bitstring).
event AAAuthorizationResponseSentPH3(bitstring).
event VehicleAuthorizationResponseReceivedPH0(bitstring).
event VehicleAuthorizationResponseReceivedPH1(bitstring).
event VehicleAuthorizationResponseReceivedPH2(bitstring).
event VehicleAuthorizationResponseReceivedPH3(bitstring).
event ValidATRequestReceivedPH0(bitstring).
event ValidATRequestReceivedPH1(bitstring).
event ValidATRequestReceivedPH2(bitstring).
event ValidATRequestReceivedPH3(bitstring).
event ValidATResponseReceivedPH0(bitstring).
event ValidATResponseReceivedPH1(bitstring).
event ValidATResponseReceivedPH2(bitstring).
event ValidATResponseReceivedPH3(bitstring).
event ATRequestSentPH0(bitstring).
event ATRequestSentPH1(bitstring).
event ATRequestSentPH2(bitstring).
event ATRequestSentPH3(bitstring).
event ATResponseSentPH0(bitstring).
event ATResponseSentPH1(bitstring).
event ATResponseSentPH2(bitstring).
event ATResponseSentPH3(bitstring).
event ValidEnrollmentCertSentVehicle(enrcertype, bitstring).
event V2XMessageSent1PH0(bitstring, skey, certype).
event V2XMessageSent1PH1(bitstring, skey, certype).
event V2XMessageSent1PH2(bitstring, skey, certype).
event V2XMessageReceived1PH0(bitstring, pkey, certype).
event V2XMessageReceived1PH1(bitstring, pkey, certype).
event V2XMessageReceived1PH2(bitstring, pkey, certype).
event V2XMessageReceived1PH3(bitstring, pkey, certype).
event V2XMessageSent2PH0(bitstring, skey).
event V2XMessageSent2PH1(bitstring, skey).
event V2XMessageSent2PH2(bitstring, skey).
event V2XMessageReceived2PH0(bitstring, pkey).
event V2XMessageReceived2PH1(bitstring, pkey).
event V2XMessageReceived2PH2(bitstring, pkey).
event V2XMessageReceived2PH3(bitstring, pkey).
event RestrictionEvent(bitstring, bitstring).

(*	CRYPTOGRAPHIC FUNCTIONS				*)

(* Asymmetric digital signature *)
fun pk(skey):pkey.
fun sign(bitstring, skey):bitstring.
fun ok():result.
reduc forall m:bitstring, sk:skey; checksign(sign(m, sk), m, pk(sk)) = ok().

(* Asymmetric encryption for key *)
fun aenc_key(symkey, pkey):bitstring.
reduc forall k:symkey, sk:skey; adec_key(aenc_key(k, pk(sk)), sk) = k.

(* Symmetric encryption *)
fun senc(bitstring, symkey):bitstring.
reduc forall m:bitstring, k: symkey; sdec(senc(m, k), k) = m.

(* Certificate *)
fun cert(bitstring, pkey, pkey, skey, bitstring, timestamp):certype.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; checkcert(cert(vid, vpk, encpk, sk, ctype, exp), pk(sk)) = ok().
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getverpk(cert(vid, vpk, encpk, sk, ctype, exp)) = vpk.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getencpk(cert(vid, vpk, encpk, sk, ctype, exp)) = encpk.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getid(cert(vid, vpk, encpk, sk, ctype, exp)) = vid.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; gettype(cert(vid, vpk, encpk, sk, ctype, exp)) = ctype.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getexp(cert(vid, vpk, encpk, sk, ctype, exp)) = exp.

(* Enrollment certificate *)
fun enrcert(bitstring, pkey, pkey, skey, bitstring, timestamp):enrcertype.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; checkenrcert(enrcert(vid, vpk, encpk, sk, ctype, exp), pk(sk)) = ok().
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getenrverpk(enrcert(vid, vpk, encpk, sk, ctype, exp)) = vpk.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getenrencpk(enrcert(vid, vpk, encpk, sk, ctype, exp)) = encpk.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getenrid(enrcert(vid, vpk, encpk, sk, ctype, exp)) = vid.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getenrtype(enrcert(vid, vpk, encpk, sk, ctype, exp)) = ctype.
reduc forall vid:bitstring, vpk:pkey, encpk:pkey, sk:skey, ctype:bitstring, exp:timestamp; getenrexp(enrcert(vid, vpk, encpk, sk, ctype, exp)) = exp.

(* Hash *)
fun hash(bitstring):bitstring.

(* Hash key *)
fun hash_key(symkey):hashkeytype.

(* Hash certificate *)
fun hash_cert(certype):hashcertype.

(* Hash enrolment certificate *)
fun hash_enrcert(enrcertype):hashenrcertype.

(* Hmac *)
fun hmac(bitstring,hmackey):bitstring.

(* Pseudo-id *)
fun pseudoid(bitstring):bitstring.

axiom nonce1:bitstring, nonce2:bitstring, x:bitstring;
	event(RestrictionEvent(nonce1, x)) && event(RestrictionEvent(nonce2, x)) ==> nonce1 = nonce2.

(* Timestamps *)
fun inc(timestamp):timestamp [data].
pred greater(timestamp, timestamp).
clauses
  forall x:timestamp; greater(inc(x),x);
  forall x:timestamp, y:timestamp; greater(x,y) -> greater(inc(x), y).
  


(*	QUERIES						*)

(* 	SANITY CHECKS					*)

(*

(* Vehicle can get an enrollment certificate in phase 0 *)
query v_sk:skey, v_enrcert:enrcertype; event(ValidEnrollmentCertReceived(v_sk, v_enrcert)).

(* Vehicle can get an authorization ticket in phase 0 *)
query v_enrsk:skey, vcert:certype; event(ValidAuthorizationTicketReceivedPH0(v_enrsk , vcert)).
(* Vehicle can get an authorization ticket in phase 2 *)
query v_enrsk:skey, vcert:certype; event(ValidAuthorizationTicketReceivedPH2(v_enrsk , vcert)).
(* Vehicle cannot get an authorization ticket in phase 3 *)
query v_enrsk:skey, vcert:certype; event(ValidAuthorizationTicketReceivedPH3(v_enrsk , vcert)).

(* Vehicle can get two authorization tickets using the same enrolment certificate in phase 0 *)
query v_enrsk:skey, vcert:certype, vcert2:certype; 
	event(ValidAuthorizationTicketReceivedPH0(v_enrsk, vcert)) && event(ValidAuthorizationTicketReceivedPH0(v_enrsk, vcert2)) && vcert<>vcert2.
(* Vehicle can get two authorization tickets using the same enrolment certificate in phase 2 *)
query v_enrsk:skey, vcert:certype, vcert2:certype; 
	event(ValidAuthorizationTicketReceivedPH2(v_enrsk, vcert)) && event(ValidAuthorizationTicketReceivedPH2(v_enrsk, vcert2)) && vcert<>vcert2.
(* Vehicle can get two authorization tickets using the same enrolment certificate in phase 0 and phase 2 *)
query v_enrsk:skey, vcert:certype, vcert2:certype; 
	event(ValidAuthorizationTicketReceivedPH0(v_enrsk, vcert)) && event(ValidAuthorizationTicketReceivedPH2(v_enrsk, vcert2)) && vcert<>vcert2.

(* EA cannot generate two different enrolment certificate for the same vehicle *)
query vehicleid:bitstring, v_enrcert:enrcertype, v_enrcert2:enrcertype; 
	event(ValidEnrollmentCertSentVehicle(v_enrcert, vehicleid)) && event(ValidEnrollmentCertSentVehicle(v_enrcert2, vehicleid)) && v_enrcert<> v_enrcert2.

(* Vehicle can send a v2x message in phase 0 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageSent1PH0(m, sk, at)).
(* Vehicle can send a v2x message in phase 1 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageSent1PH1(m, sk, at)).
(* Vehicle can send a v2x message in phase 2 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageSent1PH2(m, sk, at)).
(* Vehicle cannot send a v2x message in phase 3 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived1PH3(m, pk(sk), at)).




(* 	AUTHENTICATION					*)

(* Authentication of the vehicle to the EA in the Enrolment request *)
query m:bitstring; event(EAEnrolmentRequestReceived(m)) ==> event(VehicleEnrolmentRequestSent(m)).
query m:bitstring; inj-event(EAEnrolmentRequestReceived(m)) ==> inj-event(VehicleEnrolmentRequestSent(m)).

(* Authentication of the EA to the vehicle in the Enrolment respose *)
query m:bitstring; event(VehicleEnrolmentResponseReceived(m)) ==> event(EAEnrolmentResponseSent(m)).
query m:bitstring; inj-event(VehicleEnrolmentResponseReceived(m)) ==> inj-event(EAEnrolmentResponseSent(m)).

(* Authentication of the vehicle to the AA in the Authorization request in phase 0 - FALSE *)
query m:bitstring; event(AAAuthorizationRequestReceivedPH0(m)) ==> event(VehicleAuthorizationRequestSentPH0(m)).
query m:bitstring; inj-event(AAAuthorizationRequestReceivedPH0(m)) ==> inj-event(VehicleAuthorizationRequestSentPH0(m)).
(* Authentication of the vehicle to the AA in the Authorization request in phase 2 - FALSE *)
query m:bitstring; event(AAAuthorizationRequestReceivedPH2(m)) ==> event(VehicleAuthorizationRequestSentPH2(m)).
query m:bitstring; inj-event(AAAuthorizationRequestReceivedPH2(m)) ==> inj-event(VehicleAuthorizationRequestSentPH2(m)).

(* Authentication of the vehicle to the AA in the Authorization request in phase 3 - FALSE *)
query m:bitstring; event(AAAuthorizationRequestReceivedPH3(m)) ==> event(VehicleAuthorizationRequestSentPH3(m)).
query m:bitstring; inj-event(AAAuthorizationRequestReceivedPH3(m)) ==> inj-event(VehicleAuthorizationRequestSentPH3(m)).

(* Authentication of the AA to the EA in the AuthorizationValidation request in phase 0 *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH0(m)) ==> event(AAAuthorizationValidationRequestSentPH0(m)).
query m:bitstring; inj-event(EAAuthorizationValidationRequestReceivedPH0(m)) ==> inj-event(AAAuthorizationValidationRequestSentPH0(m)).
(* Authentication of the AA to the EA in the AuthorizationValidation request in phase 2 *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH2(m)) ==> event(AAAuthorizationValidationRequestSentPH2(m)).
query m:bitstring; inj-event(EAAuthorizationValidationRequestReceivedPH2(m)) ==> inj-event(AAAuthorizationValidationRequestSentPH2(m)).
(* Authentication of the AA to the EA in the AuthorizationValidation request in phase 3 *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH3(m)) ==> event(AAAuthorizationValidationRequestSentPH3(m)).
query m:bitstring; inj-event(EAAuthorizationValidationRequestReceivedPH3(m)) ==> inj-event(AAAuthorizationValidationRequestSentPH3(m)).
(* Request done in phase 0 not accepted in phase 2 - TRUE *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH2(m)) && event(AAAuthorizationValidationRequestSentPH0(m)).
(* Request done in phase 0 not accepted in phase 3 - TRUE *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH3(m)) && event(AAAuthorizationValidationRequestSentPH0(m)).
(* Request done in phase 2 not accepted in phase 3 - TRUE *)
query m:bitstring; event(EAAuthorizationValidationRequestReceivedPH3(m)) && event(AAAuthorizationValidationRequestSentPH2(m)).

(* Authentication of the EA to the AA in the AuthorizationValidation response in phase 0 *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH0(m)) ==> event(EAAuthorizationValidationResponseSentPH0(m)).
query m:bitstring; inj-event(AAAuthorizationValidationResponseReceivedPH0(m)) ==> inj-event(EAAuthorizationValidationResponseSentPH0(m)).
(* Authentication of the EA to the AA in the AuthorizationValidation response in phase 2 *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH2(m)) ==> event(EAAuthorizationValidationResponseSentPH2(m)).
query m:bitstring; inj-event(AAAuthorizationValidationResponseReceivedPH2(m)) ==> inj-event(EAAuthorizationValidationResponseSentPH2(m)).
(* Authentication of the EA to the AA in the AuthorizationValidation response in phase 3 *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH3(m)) ==> event(EAAuthorizationValidationResponseSentPH3(m)).
query m:bitstring; inj-event(AAAuthorizationValidationResponseReceivedPH3(m)) ==> inj-event(EAAuthorizationValidationResponseSentPH3(m)).
(* Response done in phase 0 not accepted in phase 2 - TRUE *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH2(m)) && event(EAAuthorizationValidationResponseSentPH0(m)).
(* Response done in phase 0 not accepted in phase 3 - TRUE *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH3(m)) && event(EAAuthorizationValidationResponseSentPH0(m)).
(* Response done in phase 2 not accepted in phase 3 - TRUE *)
query m:bitstring; event(AAAuthorizationValidationResponseReceivedPH3(m)) && event(EAAuthorizationValidationResponseSentPH2(m)).

(* Authentication of the AA to the vehicle in the Authorization response in phase 0 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH0(m)) ==> event(AAAuthorizationResponseSentPH0(m)).
query m:bitstring; inj-event(VehicleAuthorizationResponseReceivedPH0(m)) ==> inj-event(AAAuthorizationResponseSentPH0(m)).
(* Authentication of the AA to the vehicle in the Authorization response in phase 2 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH2(m)) ==> event(AAAuthorizationResponseSentPH2(m)).
query m:bitstring; inj-event(VehicleAuthorizationResponseReceivedPH2(m)) ==> inj-event(AAAuthorizationResponseSentPH2(m)).
(* AAAuthorizationResponseSentPH3 never happens *)
query m:bitstring; event(AAAuthorizationResponseSentPH3(m)).
(* Authentication of the AA to the vehicle in the Authorization response in phase 3 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH3(m)) ==> event(AAAuthorizationResponseSentPH3(m)).
query m:bitstring; inj-event(VehicleAuthorizationResponseReceivedPH3(m)) ==> inj-event(AAAuthorizationResponseSentPH3(m)).
(* Response done in phase 0 not accepted in phase 2 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH2(m)) && event(AAAuthorizationResponseSentPH0(m)).
(* Response done in phase 0 not accepted in phase 3 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH3(m)) && event(AAAuthorizationResponseSentPH0(m)).
(* Response done in phase 2 not accepted in phase 3 *)
query m:bitstring; event(VehicleAuthorizationResponseReceivedPH3(m)) && event(AAAuthorizationResponseSentPH2(m)).

(* Authentication of the vehicle to the EA in the Authorization request in phase 0 *)
query at_req:bitstring; event(ValidATRequestReceivedPH0(at_req)) ==> event(ATRequestSentPH0(at_req)).
query at_req:bitstring; inj-event(ValidATRequestReceivedPH0(at_req)) ==> inj-event(ATRequestSentPH0(at_req)). 
(* Authentication of the vehicle to the EA in the Authorization request in phase 2 *)
query at_req:bitstring; event(ValidATRequestReceivedPH2(at_req)) ==> event(ATRequestSentPH2(at_req)).
query at_req:bitstring; inj-event(ValidATRequestReceivedPH2(at_req)) ==> inj-event(ATRequestSentPH2(at_req)).
(* ValidATRequestReceivedPH3 never happens *)
query at_req:bitstring; event(ValidATRequestReceivedPH3(at_req)).
(* Authentication of the vehicle to the EA in the Authorization request in phase 3 *)
query at_req:bitstring; event(ValidATRequestReceivedPH3(at_req)) ==> event(ATRequestSentPH3(at_req)).
query at_req:bitstring; inj-event(ValidATRequestReceivedPH3(at_req)) ==> inj-event(ATRequestSentPH3(at_req)).
(* Request done in phase 0 not accepted in phase 2 *)
query at_req:bitstring; event(ValidATRequestReceivedPH2(at_req)) && event(ATRequestSentPH0(at_req)).
(* Request done in phase 0 not accepted in phase 3 *)
query at_req:bitstring; event(ValidATRequestReceivedPH3(at_req)) && event(ATRequestSentPH0(at_req)).
(* Request done in phase 2 not accepted in phase 3 *)
query at_req:bitstring; event(ValidATRequestReceivedPH3(at_req)) && event(ATRequestSentPH2(at_req)).

(* Authentication of the EA to the vehicle in the Authorization response in phase 0 *)
query at_req:bitstring; event(ValidATResponseReceivedPH0(at_req)) ==> event(ATResponseSentPH0(at_req)).
query at_req:bitstring; inj-event(ValidATResponseReceivedPH0(at_req)) ==> inj-event(ATResponseSentPH0(at_req)). 
(* Authentication of the EA to the vehicle in the Authorization response in phase 2 *)
query at_req:bitstring; event(ValidATResponseReceivedPH2(at_req)) ==> event(ATResponseSentPH2(at_req)).
query at_req:bitstring; inj-event(ValidATResponseReceivedPH2(at_req)) ==> inj-event(ATResponseSentPH2(at_req)). 
(* ValidATResponseReceivedPH3 never happens *)
query at_req:bitstring; event(ValidATResponseReceivedPH3(at_req)).
(* Authentication of the EA to the vehicle in the Authorization response in phase 3 *)
query at_req:bitstring; event(ValidATResponseReceivedPH3(at_req)) ==> event(ATResponseSentPH3(at_req)).
query at_req:bitstring; inj-event(ValidATResponseReceivedPH3(at_req)) ==> inj-event(ATResponseSentPH3(at_req)). 
(* Response done in phase 0 not accepted in phase 2 *)
query at_req:bitstring; event(ValidATResponseReceivedPH2(at_req)) && event(ATResponseSentPH0(at_req)).
(* Response done in phase 0 not accepted in phase 3 *)
query at_req:bitstring; event(ValidATResponseReceivedPH3(at_req)) && event(ATResponseSentPH0(at_req)).
(* Response done in phase 2 not accepted in phase 3 *)
query at_req:bitstring; event(ValidATResponseReceivedPH3(at_req)) && event(ATResponseSentPH2(at_req)).


(* Authentication of the vehicle in v2x message (1) phase 0 - FALSE, ATTACK POSSIBLE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived1PH0(m, pk(sk), at)) ==> event(V2XMessageSent1PH0(m, sk, at)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived1PH0(m, pk(sk), at)) ==> inj-event(V2XMessageSent1PH0(m, sk, at)).
(* Authentication of the vehicle in v2x message (1) phase 1 - FALSE, ATTACK POSSIBLE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived1PH1(m, pk(sk), at)) ==> event(V2XMessageSent1PH1(m, sk, at)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived1PH1(m, pk(sk), at)) ==> inj-event(V2XMessageSent1PH1(m, sk, at)).
(* Authentication of the vehicle in v2x message (1) phase 2 - FALSE, ATTACK POSSIBLE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived1PH2(m, pk(sk), at)) ==> event(V2XMessageSent1PH2(m, sk, at)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived1PH2(m, pk(sk), at)) ==> inj-event(V2XMessageSent1PH2(m, sk, at)).
(* Message sent in phase 0 not accepted in phase 1 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived1PH1(m, pk(sk), at)) && event(V2XMessageSent1PH0(m, sk, at)).

(* Authentication of the vehicle in v2x message (2) in phase 0 - TRUE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived2PH0(m, pk(sk))) ==> event(V2XMessageSent2PH0(m, sk)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived2PH0(m, pk(sk))) ==> inj-event(V2XMessageSent2PH0(m, sk)).
(* Authentication of the vehicle in v2x message (2) in phase 1 - TRUE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived2PH1(m, pk(sk))) ==> event(V2XMessageSent2PH1(m, sk)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived2PH1(m, pk(sk))) ==> inj-event(V2XMessageSent2PH1(m, sk)).
(* Authentication of the vehicle in v2x message (2) in phase 2 - TRUE *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived2PH2(m, pk(sk))) ==> event(V2XMessageSent2PH2(m, sk)).
query m:bitstring, sk:skey, at:certype; inj-event(V2XMessageReceived2PH2(m, pk(sk))) ==> inj-event(V2XMessageSent2PH2(m, sk)).
(* Message sent in phase 0 not accepted in phase 1 *)
query m:bitstring, sk:skey, at:certype; event(V2XMessageReceived2PH1(m, pk(sk))) && event(V2XMessageSent2PH0(m, sk)).

*)
















(* 	PROTOCOL MODEL					*)

(* Authorised starttime phase 0 = t4 *)
let AuthorisedVehiclePH0(v_atversk:skey, v_atencsk:skey, v_atcert:certype, starttime:timestamp) =
  
  (* Prepare the v2x message *)
  new v2xm:bitstring;
  let m = (v2xm, starttime) in

  event V2XMessageSent1PH0(m, v_atversk, v_atcert);
  event V2XMessageSent2PH0(m, v_atversk);
  out(ch, (m, sign(m, v_atversk), v_atcert))
.

(* Authorised starttime phase 1 = t5 *)
let AuthorisedVehiclePH1(v_atversk:skey, v_atencsk:skey, v_atcert:certype, starttime:timestamp) =
  
  (* Prepare the v2x message *)
  new v2xm:bitstring;
  let m = (v2xm, starttime) in

  event V2XMessageSent1PH1(m, v_atversk, v_atcert);
  event V2XMessageSent2PH1(m, v_atversk);
  out(ch, (m, sign(m, v_atversk), v_atcert))
.

(* Authorised starttime phase 2 = t9 *)
let AuthorisedVehiclePH2(v_atversk:skey, v_atencsk:skey, v_atcert:certype, starttime:timestamp) =
  
  (* Prepare the v2x message *)
  new v2xm:bitstring;
  let m = (v2xm, starttime) in

  event V2XMessageSent1PH2(m, v_atversk, v_atcert);
  event V2XMessageSent2PH2(m, v_atversk);
  out(ch, (m, sign(m, v_atversk), v_atcert))
.

(* VerifyV2XMessage actualtime phase 0 = t4 *)
let VerifyV2XMessagePH0(aa_cert:certype, serviceattributes:bitstring, actualtime:timestamp) = 
  
  (* Receive the v2x message *)
  in(ch, (m:bitstring, sign_m:bitstring, atcert:certype));

  let (v2xm:bitstring, gentime:timestamp) = m in

  (* Check signature *)
  if checksign(sign_m, m, getverpk(atcert)) = ok() then

  (* Verify at *)
  if checkcert(atcert, getverpk(aa_cert)) = ok() then
  if gettype(atcert) = serviceattributes then

  (* Verify timestamp *)
  if greater(getexp(atcert), gentime) then
  if actualtime = gentime then

  event V2XMessageReceived1PH0(m, getverpk(atcert), atcert);
  event V2XMessageReceived2PH0(m, getverpk(atcert))
.

(* VerifyV2XMessage actualtime phase 1 = t5 *)
let VerifyV2XMessagePH1(aa_cert:certype, serviceattributes:bitstring, actualtime:timestamp) = 
  
  (* Receive the v2x message *)
  in(ch, (m:bitstring, sign_m:bitstring, atcert:certype));

  let (v2xm:bitstring, gentime:timestamp) = m in

  (* Check signature *)
  if checksign(sign_m, m, getverpk(atcert)) = ok() then

  (* Verify at *)
  if checkcert(atcert, getverpk(aa_cert)) = ok() then
  if gettype(atcert) = serviceattributes then

  (* Verify timestamp *)
  if greater(getexp(atcert), gentime) then
  if actualtime = gentime then

  event V2XMessageReceived1PH1(m, getverpk(atcert), atcert);
  event V2XMessageReceived2PH1(m, getverpk(atcert))
.

(* VerifyV2XMessage actualtime phase 2 = t9 *)
let VerifyV2XMessagePH2(aa_cert:certype, serviceattributes:bitstring, actualtime:timestamp) = 
  
  (* Receive the v2x message *)
  in(ch, (m:bitstring, sign_m:bitstring, atcert:certype));

  let (v2xm:bitstring, gentime:timestamp) = m in

