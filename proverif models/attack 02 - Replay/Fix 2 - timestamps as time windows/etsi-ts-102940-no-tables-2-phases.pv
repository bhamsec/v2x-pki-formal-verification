.

(* VerifyV2XMessage actualtime phase 3 = t14 *)
let VerifyV2XMessagePH3(aa_cert:certype, serviceattributes:bitstring, actualtime:timestamp) = 
  
  (* Receive the v2x message *)
  in(ch, (m:bitstring, sign_m:bitstring, atcert:certype));

  let (v2xm:bitstring, gentime:timestamp) = m in

